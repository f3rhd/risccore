.bubble_sort:
        PARAM $bubble_sort::array
        PARAM $bubble_sort::size
        $b0::i = 0
        GOTO .L0
.L0:
        $b1::j = 0
        $b1::swapped = 0
        GOTO .L2
.L2:
        SLL @t0,$b1::j,2
        ADD @t1,$bubble_sort::array,@t0
        LOAD @t3,@t1
        ADD @t4,$b1::j,1
        SLL @t5,@t4,2
        ADD @t6,$bubble_sort::array,@t5
        LOAD @t8,@t6
        BLE @t3,@t8, .L4
.L6:
        ADD @t9,$b1::j,1
        SLL @t10,@t9,2
        ADD @t11,$bubble_sort::array,@t10
        LOAD @t13,@t11
        $b3::temp = @t13
        ADD @t14,$b1::j,1
        SLL @t15,@t14,2
        ADD @t16,$bubble_sort::array,@t15
        SLL @t18,$b1::j,2
        ADD @t19,$bubble_sort::array,@t18
        LOAD @t21,@t19
        STORE @t21,()@t16
        SLL @t23,$b1::j,2
        ADD @t24,$bubble_sort::array,@t23
        STORE $b3::temp,()@t24
        $b1::swapped = 1
.L4:
        NOP
.L3:
        ADD $b1::j,$b1::j,1
        SUB @t28,$bubble_sort::size,$b0::i
        SUB @t29,@t28,1
        BLT $b1::j,@t29, .L2
.L7:
        NOP
.L8:
        BNEQ $b1::swapped,0, .L9
.L11:
        RETURN
.L9:
        NOP
.L1:
        ADD $b0::i,$b0::i,1
        BLT $b0::i,$bubble_sort::size, .L0
.L12:
        NOP
.L13:
        NOP
.is_sorted:
        PARAM $is_sorted::array
        PARAM $is_sorted::size
        $b5::i = 0
        $b5::is_sorted = 1
        GOTO .L14
.L14:
        SLL @t31,$b5::i,2
        ADD @t32,$is_sorted::array,@t31
        LOAD @t34,@t32
        ADD @t35,$b5::i,1
        SLL @t36,@t35,2
        ADD @t37,$is_sorted::array,@t36
        LOAD @t39,@t37
        BLE @t34,@t39, .L16
.L18:
        $b5::is_sorted = 0
        RETURN $b5::is_sorted
.L16:
        NOP
.L15:
        ADD $b5::i,$b5::i,1
        SUB @t41,$is_sorted::size,1
        BLT $b5::i,@t41, .L14
.L19:
        NOP
.L20:
        RETURN $b5::is_sorted
.main:
        ALLOC $test_array,20
        LI @t42,5
        STORE @t42,(0)$test_array
        LI @t43,4
        STORE @t43,(4)$test_array
        LI @t44,3
        STORE @t44,(8)$test_array
        LI @t45,2
        STORE @t45,(12)$test_array
        LI @t46,1
        STORE @t46,(16)$test_array
        ARG $test_array
        ARG 5
        @t47 = CALL .bubble_sort
        ARG $test_array
        ARG 5
        @t48 = CALL .is_sorted
        $b8::is_sorted_flag = @t48
        BNEQ $b8::is_sorted_flag,1, .L21
.L23:
        GOTO .L24
.L25:
        NOP
.L24:
        BNEQ 1,0, .L25
.L26:
        NOP
.L27:
        NOP
.L21: